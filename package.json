{
  "name": "jmc1",
  "version": "1.0.0",
  "description": "Website template for Payload",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:analyze": "cross-env ANALYZE=true NODE_OPTIONS=--no-deprecation next build",
    "analyze:deps": "npx depcheck",
    "analyze:size": "npx bundle-size-analyzer .next/static/chunks/*.js",
    "postbuild": "next-sitemap --config next-sitemap.config.cjs",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:prod": "cross-env NODE_OPTIONS=--no-deprecation rm -rf .next && pnpm build && pnpm start",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "ii": "cross-env NODE_OPTIONS=--no-deprecation pnpm --ignore-workspace install",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "reinstall": "cross-env NODE_OPTIONS=--no-deprecation rm -rf node_modules && rm pnpm-lock.yaml && pnpm --ignore-workspace install",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.0.1",
    "@payloadcms/db-mongodb": "3.41.0",
    "@payloadcms/live-preview-react": "3.41.0",
    "@payloadcms/next": "3.41.0",
    "@payloadcms/payload-cloud": "3.41.0",
    "@payloadcms/plugin-form-builder": "3.41.0",
    "@payloadcms/plugin-nested-docs": "3.41.0",
    "@payloadcms/plugin-redirects": "3.41.0",
    "@payloadcms/plugin-search": "3.41.0",
    "@payloadcms/plugin-seo": "3.41.0",
    "@payloadcms/richtext-lexical": "3.41.0",
    "@payloadcms/storage-vercel-blob": "3.41.0",
    "@payloadcms/ui": "3.33.0",
    "@radix-ui/react-checkbox": "^1.3.2",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slot": "^1.2.3",
    "@vercel/blob": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "geist": "^1.4.2",
    "graphql": "^16.11.0",
    "lucide-react": "^0.513.0",
    "mongodb": "^6.17.0",
    "next": "15.3.3",
    "next-sitemap": "^4.2.3",
    "node-fetch": "^3.3.2",
    "payload": "3.41.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "7.57.0",
    "react-image-crop": "^11.0.10",
    "sharp": "^0.34.2",
    "swiper": "^11.2.8",
    "tailwind-merge": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@next/bundle-analyzer": "^15.3.3",
    "@tailwindcss/typography": "^0.5.16",
    "@types/node": "22.15.30",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "autoprefixer": "^10.4.21",
    "depcheck": "^1.4.7",
    "eslint": "^9.28.0",
    "eslint-config-next": "15.3.3",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.3.0",
    "typescript": "5.8.3",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "engines": {
    "node": "^18.20.2 || >=20.9.0",
    "pnpm": "^9 || ^10"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "sharp"
    ],
    "patchedDependencies": {
      "react-image-crop@10.1.8": "patches/react-image-crop@10.1.8.patch"
    }
  }
}
